# DeveLogic Accounting - Environment Configuration Example
# Do not place real production secrets in this file.

# ------------------------------------------------------------------------------
# Client (Vite) - Required for good local UX
# ------------------------------------------------------------------------------
VITE_APP_BASE_URL=http://localhost:5173
VITE_FEATURE_EMAIL_ENABLED=true
VITE_FEATURE_REPORTS_ENABLED=true
VITE_EMAIL_MAX_ATTACHMENT_MB=5
 
# ------------------------------------------------------------------------------
# Client (Vite) - Optional integration placeholders
# ------------------------------------------------------------------------------
# Required later when connecting real Supabase persistence/auth/storage.
VITE_SUPABASE_URL=https://psoctrhfkumppwzinygp.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InBzb2N0cmhma3VtcHB3emlueWdwIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzU3MzA4MjMsImV4cCI6MjA5MTMwNjgyM30.X_j4sNvx7-WXHluxCuPmeoH95nc3_OwgSvlad66PxMc
VITE_SUPABASE_STORAGE_BUCKET=https://psoctrhfkumppwzinygp.storage.supabase.co/storage/v1/s3
VITE_SUPABASE_EMAIL=accounts@develogic-digital.com
VITE_SUPABASE_PASSWORD=@cc0untskn0wsm3!
VITE_EMAIL_TRANSPORT_MODE=mock

# ------------------------------------------------------------------------------
# Server (Vercel API routes) - Email transport
# ------------------------------------------------------------------------------
# Modes:
# - mock: no real email delivery; useful for local development
# - smtp: real email transport via SMTP credentials
# - disabled: sending endpoint available but always disabled
EMAIL_TRANSPORT_MODE=mock

# Required when EMAIL_TRANSPORT_MODE=smtp
SMTP_HOST=mail.develogic-digital.com
SMTP_PORT=465
SMTP_USER=accounts@develogic-digital.com
SMTP_PASS=@cc0untskn0wsm3!
SMTP_FROM_EMAIL=accounts@develogic-digital.com
SMTP_FROM_NAME=DeveLogic Accounting

# Maximum attachment size accepted by send endpoint
EMAIL_MAX_ATTACHMENT_MB=5

# ------------------------------------------------------------------------------
# Server security hardening (optional but recommended)
# ------------------------------------------------------------------------------
# Comma-separated origins allowed to call /api/email/* when origin enforcement is on.
APP_ALLOWED_ORIGINS=http://localhost:5173
ENFORCE_EMAIL_ORIGIN_CHECK=false
