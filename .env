# ------------------------------------------------------------------------------
# Supabase user bootstrap script (server-side, one-time setup)
# ------------------------------------------------------------------------------
# Run: npm run users:bootstrap
# Uses Supabase Admin API via service role key to create/update auth users and business roles.
SUPABASE_URL=https://psoctrhfkumppwzinygp.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InBzb2N0cmhma3VtcHB3emlueWdwIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3NTczMDgyMywiZXhwIjoyMDkxMzA2ODIzfQ.aEkFafhlJPfmnjaZa7mkmZ2aC8KJzmixWLjyrH3MIVo
